<form class='{{cssClass}}' autocomplete='off'>
  <div class=''>
    <div class='header-bar'>
      <img class='profile-img' src='{{actor.img}}' title='{{actor.name}}' data-edit='img' />
      <div class='header-info'>
        <input
          class='name'
          name='name'
          type='text'
          value='{{actor.name}}'
          placeholder='{{localize "godbound.sheet.name"}}'
        />
        <div class='hp'>
          <label class='label-padding'>{{localize 'godbound.sheet.hp'}}:</label>
          <input
            type='number'
            step='1'
            name='data.hp.value'
            value='{{actor.data.data.hp.value}}'
            data-dtype='Number'
            min='0'
          />
          <span class='span-padding'>/</span>
          <input
            type='number'
            name='data.hp.max'
            value='{{actor.data.data.hp.max}}'
            step='1'
            min='1'
            data-dtype='Number'
          />
        </div>
        <div class='ac'>
          <label class='label-padding'>{{localize 'godbound.sheet.ac'}}:</label>
          <div>{{actor.data.data.ac.value}}</div>
        </div>
        <div class='xp'>
          <label class='label-padding'>{{localize 'godbound.sheet.xp'}}:</label>
          <input
            type='number'
            step='1'
            name='data.details.xp.value'
            value='{{actor.data.data.details.xp.value}}'
            data-dtype='Number'
            min='0'
          />
          <span class='span-padding'>/</span>
          <input
            type='number'
            name='data.details.xp.next'
            value='{{actor.data.data.details.xp.next}}'
            step='1'
            min='1'
            data-dtype='Number'
          />
        </div>
        <div class='level'>
          <label class='label-padding'>{{localize 'godbound.sheet.level'}}:</label>
          <input
            type='number'
            step='1'
            name='data.details.level'
            value='{{actor.data.data.details.level}}'
            data-dtype='Number'
            min='0'
          />
        </div>
      </div>
    </div>
  </div>
  <div class='main-body'>
    <div class='sidebar'>
      <div class='attributes'>
        <table>
          <thead>
            <tr>
              <th>
                {{localize 'godbound.sheet.attributes'}}
              </th>
              <th>
                {{localize 'godbound.sheet.value'}}
              </th>
              <th>
                {{localize 'godbound.sheet.mod'}}
              </th>
            </tr>
          </thead>
          {{#each actor.data.data.attributes as |stat key|}}
            <tr>
              <td>
                <label for='data.stats.{{key}}.value'>
                  {{localize (concat 'godbound.attributes.' key)}}
                </label>
              </td>
              <td>
                <input
                  type='number'
                  min='3'
                  max='18'
                  step='1'
                  name='data.attributes.{{key}}.value'
                  value='{{stat.value}}'
                  data-dtype='Number'
                />
              </td>
              <td>
                <span>
                  {{stat.mod}}
                </span>
              </td>
            </tr>
          {{/each}}
        </table>

      </div>
      <div class='effort'>
        <table>
          <thead>
            <tr>
              <th>
                {{localize 'godbound.effort.effort'}}
              </th>
            </tr>
          </thead>
          <td>
            <table>
              <thead>
                <tr>
                  <th>
                    {{localize 'godbound.effort.available'}}
                  </th>
                  <th>
                    {{localize 'godbound.effort.maximum'}}
                  </th>
                </tr>
              </thead>
              <tr>
                <td>
                  {{actor.data.data.resources.effort.value}}
                </td>
                <td>
                  {{actor.data.data.resources.effort.max}}
                </td>
              </tr>
            </table>
            <table>
              <thead>
                <tr>
                  <th>
                    {{localize 'godbound.effort.committedTimes.ongoing'}}
                  </th>
                  <th>
                    {{localize 'godbound.effort.committedTimes.scene'}}
                  </th>
                  <th>
                    {{localize 'godbound.effort.committedTimes.day'}}
                  </th>
                </tr>
              </thead>
              <tr>
                <td>
                  {{actor.data.data.resources.effort.ongoing}}
                </td>
                <td>
                  {{actor.data.data.resources.effort.scene}}
                </td>
                <td>
                  {{actor.data.data.resources.effort.day}}
                </td>
              </tr>
            </table>
          </td>
        </table>
      </div>
      <div class='saves'>
        <div data-save-type='hardiness' class='save'>
          {{localize 'godbound.saves.hardiness'}}
          v{{subtract actor.data.data.saves.hardiness.base actor.data.data.saves.hardiness.mod}}
          <i class='fas fa-dice-d20'></i>
        </div>
        <div data-save-type='evasion' class='save'>
          {{localize 'godbound.saves.evasion'}}
          v{{subtract actor.data.data.saves.hardiness.base actor.data.data.saves.hardiness.mod}}
          <i class='fas fa-dice-d20'></i>
        </div>
        <div data-save-type='spirit' class='save'>
          {{localize 'godbound.saves.spirit'}}
          v{{subtract actor.data.data.saves.hardiness.base actor.data.data.saves.hardiness.mod}}
          <i class='fas fa-dice-d20'></i>
        </div>
      </div>
    </div>
    <div class='main-body-center'>
      <nav>

      </nav>
    </div>
  </div>
</form>